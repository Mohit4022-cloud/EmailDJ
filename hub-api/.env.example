# EmailDJ Hub API — Environment Variables
# Copy to .env and fill in real values before running

# ── LLM Providers ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...               # Required when EMAILDJ_REAL_PROVIDER=openai or preview pipeline is on.
ANTHROPIC_API_KEY=sk-ant-...        # Required when EMAILDJ_REAL_PROVIDER=anthropic.
GROQ_API_KEY=gsk_...                # Required when EMAILDJ_REAL_PROVIDER=groq.
EMAILDJ_REAL_PROVIDER=openai        # Deployed provider preference: openai|anthropic|groq.
USE_PROVIDER_STUB=0                 # Deployed services must use 0. Set 1 only for local/test stub mode.
EMAILDJ_QUICK_GENERATE_MODE=real    # Legacy override. Mock is ignored unless USE_PROVIDER_STUB=1.

# ── LangSmith Tracing ───────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=emaildj-prod

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0  # Required for deployed hub-api services. Localhost is local-dev only.
REDIS_FORCE_INMEMORY=0              # Local/test only. Staging/prod must stay 0 and use managed REDIS_URL.

# ── Vector Store ────────────────────────────────────────────────
VECTOR_STORE_BACKEND=pinecone   # or "pgvector"
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=emaildj-contexts
PINECONE_ENVIRONMENT=us-east-1

# ── PostgreSQL (pgvector path) ──────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/emaildj

# ── Salesforce CRM ──────────────────────────────────────────────
SALESFORCE_CLIENT_ID=...
SALESFORCE_CLIENT_SECRET=...
SALESFORCE_REDIRECT_URI=http://localhost:8000/auth/callback
SALESFORCE_API_VERSION=v59.0
SALESFORCE_INSTANCE_URL=https://your-instance.my.salesforce.com
SALESFORCE_ACCESS_TOKEN=...

# ── Campaign Intelligence Providers ─────────────────────────────
EMAILDJ_CAMPAIGN_INTELLIGENCE_MODE=auto  # auto|real|mock|fallback
EMAILDJ_CRM_PROVIDER=salesforce          # salesforce|mock
EMAILDJ_INTENT_PROVIDER=bombora          # bombora|mock
BOMBORA_API_KEY=...
BOMBORA_API_URL=https://api.bombora.com/v1/company-surge

# ── Web Search (Deep Research) ──────────────────────────────────
SERPER_API_KEY=...             # primary
BRAVE_SEARCH_API_KEY=...       # fallback

# ── Slack (cost guard alerts) ───────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
PROVIDER_FAILURE_METRICS_WEBHOOK_URL=https://metrics.example.com/events
ALERT_SINK_TIMEOUT_SECONDS=5

# ── App Settings ────────────────────────────────────────────────
CHROME_EXTENSION_ORIGIN=chrome-extension://YOUR_EXTENSION_ID  # Required CORS origin for the shipped extension.
WEB_APP_ORIGIN=http://localhost:5174                         # Required in staging/prod. Use the deployed Vercel frontend origin.
EMAILDJ_WEB_BETA_KEYS=dev-beta-key                          # Required in staging/prod. Replace with secret non-dev beta key values.
EMAILDJ_WEB_RATE_LIMIT_PER_MIN=30                           # Required in staging/prod. Pin an explicit per-key request limit.
EMAILDJ_PRESET_PREVIEW_PIPELINE=off                         # Set on only when preview routes are intentionally exposed.
EMAILDJ_OPENAI_MODEL=gpt-5-nano
EMAILDJ_OPENAI_REASONING_EFFORT=high         # minimal|low|medium|high
EMAILDJ_PRESET_PREVIEW_MODEL_EXTRACTOR=gpt-5-nano
EMAILDJ_PRESET_PREVIEW_MODEL_GENERATOR=gpt-5-nano
EMAILDJ_PRESET_PREVIEW_MODEL_FALLBACK=gpt-5-nano
EMAILDJ_PRESET_PREVIEW_SUMMARY_CACHE_TTL_SEC=900
EMAILDJ_PREVIEW_INCLUDE_SUMMARY_PACK=0
EMAILDJ_PREVIEW_ENFORCEMENT_LEVEL=warn             # warn|repair|block
EMAILDJ_STRICT_LOCK_ENFORCEMENT_LEVEL=repair   # warn|repair|block
EMAILDJ_REPAIR_LOOP_ENABLED=1                  # 1|0
EMAILDJ_DEBUG_SUCCESS_SAMPLE_RATE=0.01         # 0.0-1.0
APP_ENV=local                               # local|staging|prod. Staging/prod reject localhost web origins and dev beta keys.
MONTHLY_COST_CEILING=100
MONTHLY_COST_THROTTLE_MULTIPLIER=3
BLAST_RADIUS_CONFIRM_THRESHOLD=200
CONTEXT_VAULT_CACHE_TTL_SECONDS=3600
DEEP_RESEARCH_RATE_LIMIT_PER_HOUR=200
DEEP_RESEARCH_JOB_TTL_SECONDS=86400
QUICK_REQUEST_TTL_SECONDS=300
QUICK_MAX_CONCURRENT_STREAMS=32
QUICK_PROVIDER_FAILURE_ALERT_THRESHOLD=5
QUICK_PROVIDER_FAILURE_ALERT_STEP=5
EMAILDJ_EXTRACTOR_ENABLE_ENRICHMENT=0
EMAILDJ_EXTRACTOR_ENRICH_CONFIDENCE_MIN=0.75
LOG_LEVEL=INFO
