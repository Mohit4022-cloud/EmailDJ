# EmailDJ Hub API — Environment Variables
# Copy to .env and fill in real values before running

# ── LLM Providers ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ── LangSmith Tracing ───────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=emaildj-prod

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Vector Store ────────────────────────────────────────────────
VECTOR_STORE_BACKEND=pinecone   # or "pgvector"
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=emaildj-contexts
PINECONE_ENVIRONMENT=us-east-1

# ── PostgreSQL (pgvector path) ──────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/emaildj

# ── Salesforce CRM ──────────────────────────────────────────────
SALESFORCE_CLIENT_ID=...
SALESFORCE_CLIENT_SECRET=...
SALESFORCE_REDIRECT_URI=http://localhost:8000/auth/callback
SALESFORCE_API_VERSION=v59.0

# ── Web Search (Deep Research) ──────────────────────────────────
SERPER_API_KEY=...             # primary
BRAVE_SEARCH_API_KEY=...       # fallback

# ── Slack (cost guard alerts) ───────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── App Settings ────────────────────────────────────────────────
CHROME_EXTENSION_ORIGIN=chrome-extension://YOUR_EXTENSION_ID
MONTHLY_COST_THROTTLE_MULTIPLIER=3
BLAST_RADIUS_CONFIRM_THRESHOLD=200
CONTEXT_VAULT_CACHE_TTL_SECONDS=3600
DEEP_RESEARCH_RATE_LIMIT_PER_HOUR=200
