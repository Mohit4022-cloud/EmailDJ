# Backend runtime
APP_ENV=local
WEB_APP_ORIGIN=http://localhost:5174
EMAILDJ_WEB_BETA_KEYS=dev-beta-key
EMAILDJ_WEB_RATE_LIMIT_PER_MIN=60
LOG_LEVEL=INFO

# OpenAI (server-side only)
OPENAI_API_KEY=
EMAILDJ_OPENAI_MODEL=gpt-5-nano
EMAILDJ_OPENAI_REASONING_EFFORT_HIGH=high
EMAILDJ_OPENAI_REASONING_EFFORT_LOW=minimal

# Retrieval providers (tool-only external fetch)
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=

# Caching
EMAILDJ_CACHE_TARGET_TTL_SECONDS=604800
EMAILDJ_CACHE_NEWS_TTL_SECONDS=86400
EMAILDJ_CACHE_CONTACT_TTL_SECONDS=1209600
EMAILDJ_CACHE_SENDER_TTL_SECONDS=604800

# Streaming
EMAILDJ_STREAM_CHUNK_SIZE=48
