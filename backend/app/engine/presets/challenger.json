{
  "preset_id": "challenger",
  "name": "Challenger",
  "tone_descriptor": "assertive, insight-led, pragmatic",
  "style_rules": [
    "Start by reframing a likely cost of inaction",
    "State one clear point of view tied to business impact",
    "Keep critique respectful and specific"
  ],
  "output_contract": {
    "tone": "insight-led and pragmatic",
    "assertiveness": "high",
    "opener_directness": "direct",
    "cta_placement": "final_exact",
    "proof_density": "tight",
    "lengths": {
      "short": {
        "target_word_range": {"min": 52, "max": 78},
        "hard_word_range": {"min": 46, "max": 88},
        "sentence_count_guidance": {"target_min": 3, "target_max": 4, "hard_max": 5}
      },
      "medium": {
        "target_word_range": {"min": 88, "max": 122},
        "hard_word_range": {"min": 80, "max": 134},
        "sentence_count_guidance": {"target_min": 4, "target_max": 5, "hard_max": 6}
      },
      "long": {
        "target_word_range": {"min": 128, "max": 178},
        "hard_word_range": {"min": 118, "max": 194},
        "sentence_count_guidance": {"target_min": 5, "target_max": 6, "hard_max": 7}
      }
    }
  },
  "structure_rules": [
    "reframe -> impact -> proof -> CTA",
    "No more than one contrarian claim"
  ],
  "banned_phrases_additions": [
    "game changer",
    "revolutionary"
  ],
  "formatting_hints": "Plain text, no bullet points unless long format"
}
